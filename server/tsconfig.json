{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": "./src",
    "outDir": "./dist",

    "resolveJsonModule": true,
    "allowJs": false,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}